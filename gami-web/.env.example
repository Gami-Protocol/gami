VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Point at the redesigned Next.js waitlist API (recommended)
# e.g. https://gamiprotocol.io/api/waitlist or http://localhost:3000/api/waitlist
VITE_WAITLIST_API_URL=
VITE_PRIVY_APP_ID=cmr6honh400ee0cjudyfx9hpt
# WalletConnect Cloud project ID — enables QR connect for MetaMask mobile, Rainbow, etc.
VITE_WALLETCONNECT_PROJECT_ID=
# Flip to true only when on-chain contributions should accept funds.
VITE_SALE_LIVE=false
VITE_CHAIN_ID=84532
VITE_VESTING_ADDRESS=
VITE_TOKEN_SALE_ADDRESS=
VITE_GAMI_TOKEN_ADDRESS=
VITE_USDC_ADDRESS=

# Payment gateway — card / fiat → USDC (sale always settles in USDC on-chain)
# Coinbase card funding uses Privy (VITE_PRIVY_APP_ID). Enable Coinbase/Moonpay in the Privy dashboard.
# Ramp Network Instant for card / Apple Pay / Google Pay → BASE_USDC
VITE_RAMP_HOST_API_KEY=
# production (default) or demo
VITE_RAMP_ENVIRONMENT=demo
# Optional override deep-links (support {wallet}, {address}, {amount}, {usdc})
VITE_FIAT_ONRAMP_URL=
VITE_USDT_SWAP_URL=
VITE_APP_STORE_URL=
VITE_PLAY_STORE_URL=
VITE_TESTFLIGHT_URL=https://testflight.apple.com/join/71dW2rQP

# KYC (Persona template — set when provider account is ready)
VITE_KYC_PROVIDER=persona
VITE_PERSONA_TEMPLATE_ID=
VITE_PERSONA_ENVIRONMENT=sandbox
# Hosted provider flow; supports {wallet} placeholder.
VITE_KYC_VERIFICATION_URL=

# Geo-block (comma-separated ISO country codes)
VITE_BLOCKED_COUNTRIES=US,CU,IR,KP,SY

# Sale edge functions base (defaults to SUPABASE_URL/functions/v1)
VITE_SUPABASE_FUNCTIONS_URL=
