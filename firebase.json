{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "*.local"],
      "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
    }
  ],
  "auth": {
    "providers": {
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": "Gami Protocol",
        "supportEmail": "support@gami.xyz",
        "authorizedRedirectUris": [
          "https://gamiprotocol.io",
          "https://www.gamiprotocol.io",
          "https://gami.xyz",
          "https://www.gami.xyz",
          "http://localhost",
          "http://localhost:3000",
          "http://localhost:5173"
        ]
      }
    }
  }
}
