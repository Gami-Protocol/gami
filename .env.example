# ICO Web Portal
EXPO_PUBLIC_ICO_WEB_URL=https://gami.xyz
EXPO_PUBLIC_ICO_CLAIM_URL=https://gami.xyz/claim

# On-chain (Base Sepolia for testnet, Base for mainnet)
EXPO_PUBLIC_GAMI_CHAIN=baseSepolia
