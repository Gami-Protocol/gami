# Gami Wallet + ICO Environment

# Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Privy
EXPO_PUBLIC_PRIVY_APP_ID=
