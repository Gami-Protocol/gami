{
  "name": "gami-contracts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy-sepolia.ts --network baseSepolia",
    "configure:sale": "hardhat run scripts/configure-sale.ts --network baseSepolia",
    "finalize:sale": "hardhat run scripts/finalize-sale.ts --network baseSepolia",
    "merkle:whitelist": "hardhat run scripts/merkle-whitelist.ts --network baseSepolia",
    "test:e2e": "hardhat run scripts/e2e-testnet.ts --network hardhat",
