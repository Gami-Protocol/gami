    "verify": "hardhat verify"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.3.0",
    "dotenv": "^16.4.7",
    "hardhat": "^2.22.17",
    "merkletreejs": "^0.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
